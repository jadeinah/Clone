Tabs.Placer:AddButton({
    Title = "🏠 Place Everything (Full Auto)",
    Callback = function()
        if not scannedData or #scannedData.furnitures == 0 then 
            return Fluent:Notify({ Title = "Error", Content = "No data to place.", Duration = 3 }) 
        end

        isWorking = true 
        local API = ReplicatedStorage:WaitForChild("API")
        local totalPlaced = 0
        
        if scannedData.textures then
            local BuyTexture = API:WaitForChild("HousingAPI/BuyTexture")
            for i, tex in ipairs(scannedData.textures) do
                if not isWorking then break end
                pcall(function() BuyTexture:FireServer(tex.room, tex.type, tex.id) end)
                PlaceStatus:SetDesc(string.format("🎨 Placing textures... %d/%d", i, #scannedData.textures))
                task.wait(globalWaitTime)
            end
        end
        
        if isWorking and scannedData.ambiances and next(scannedData.ambiances) then
            local UpdateAmbiance = API:WaitForChild("AmbianceAPI/UpdateAmbiance")
            pcall(function()
                local amb = scannedData.ambiances
                local function fixColor(obj)
                    if type(obj)=="table" then 
                        for k,v in pairs(obj) do 
                            if type(v)=="table" then 
                                if v[1] and type(v[1])=="number" and #v >= 3 then 
                                    obj[k]=Color3.new(v[1],v[2],v[3]) 
                                else 
                                    fixColor(v) 
                                end 
                            end 
                        end 
                    end
                end
                fixColor(amb)
                UpdateAmbiance:FireServer(amb)
            end)
            task.wait(globalWaitTime)
        end
        
        local BuyFurnitures = API:WaitForChild("HousingAPI/BuyFurnitures")
        for i, furn in ipairs(scannedData.furnitures) do
            if not isWorking then break end

            pcall(function()
                local d = { kind = furn.kind, properties = { scale = furn.properties.scale } }
                if furn.properties.cframe then 
                    d.properties.cframe = CFrame.new(unpack(furn.properties.cframe)) 
                end
                if furn.properties.colors then
                    local c = {}
                    for j, color in pairs(furn.properties.colors) do 
                        c[j] = (type(color)=="table" and #color==3) and Color3.new(color[1],color[2],color[3]) or color 
                    end
                    d.properties.colors = c
                end
                BuyFurnitures:InvokeServer({d})
            end)
            if i % 5 == 0 then PlaceStatus:SetDesc(string.format("🪑 Placing furnitures... %d/%d", i, #scannedData.furnitures)) end
            task.wait(globalWaitTime)
            totalPlaced += 1
        end
        
        isWorking = false
        PlaceStatus:SetDesc(string.format("✅ Complete! Total: %d placed", totalPlaced))
        Fluent:Notify({ Title = "✅ Done!", Content = "Placement finished.", Duration = 5 })
    end
})

