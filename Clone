-- ==================== SMART DATABASE & PRICE EXTRACTOR ====================
local CachedFurnitureDB = nil

local function getFurnitureDatabase()
    if CachedFurnitureDB then return CachedFurnitureDB end
    local db = {}
    
    local success, err = pcall(function()
        local Fsys = require(game:GetService("ReplicatedStorage").Fsys)
        local ContentPackHelper = Fsys.load("ContentPackHelper")
        
        ContentPackHelper.foreach("Furniture", function(pack)
            for _, item in pairs(pack) do
                local key = item.kind or item.id or item.name
                if key then db[tostring(key)] = item end
            end
        end)
    end)
    
    if success and next(db) then 
        CachedFurnitureDB = db 
        return db
    end
    
    pcall(function()
        local rawDB = nil
        if ClientData.get then 
            rawDB = ClientData.get("furniture_data") or ClientData.get("furniture") 
        end
        if not rawDB and ClientData.get_data then 
            rawDB = ClientData.get_data().furniture_data 
        end
        
        if type(rawDB) == "table" then
            for k, v in pairs(rawDB) do
                local key = k or (type(v) == "table" and (v.kind or v.id or v.name))
                if key then db[tostring(key)] = v end
            end
        end
    end)
    
    CachedFurnitureDB = next(db) and db or nil
    return CachedFurnitureDB
end

local function extractPrice(fData)
    if type(fData) ~= "table" then return 0 end
    
    local function findNumberInTable(tbl)
        if type(tbl) ~= "table" then return nil end
        local currencyKeys = {"bucks", "Bucks", "robux", "Robux", "value", "Value", "amount", "price", "Price", "cost", "Cost", "money", "Money"}
        for _, k in ipairs(currencyKeys) do
            if type(tbl[k]) == "number" then return tbl[k] end
        end
        for _, v in pairs(tbl) do
            if type(v) == "number" then return v end
        end
        return nil
    end

    local knownKeys = {"price", "Price", "cost", "Cost", "bucks", "Bucks", "money", "Money", "buy_price", "amount", "value", "Value"}
    for _, key in ipairs(knownKeys) do
        local val = fData[key]
        if val then
            if type(val) == "number" then return val
            elseif type(val) == "table" then
                local num = findNumberInTable(val)
                if num then return num end
            end
        end
    end
    return 0
end

local function calculateCost(data)
    local totalItems = 0
    local estCost = 0
    if not data or type(data.furnitures) ~= "table" then return totalItems, estCost end

    local FurnitureData = getFurnitureDatabase()
    for _, furn in ipairs(data.furnitures) do
        totalItems += 1
        if FurnitureData then
            pcall(function()
                local fData = FurnitureData[furn.kind] or FurnitureData[tostring(furn.kind)]
                if not fData then
                    for _, v in pairs(FurnitureData) do
                        if type(v) == "table" and (v.id == furn.kind or v.name == furn.kind or v.kind == furn.kind) then
                            fData = v
                            break
                        end
                    end
                end
                if type(fData) == "table" then estCost += extractPrice(fData) end
            end)
        end
    end
    return totalItems, estCost
end

