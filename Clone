-- ==================== DETERMINISTIC CLONE DETECTION & AUTO-SCANNER ====================
local function getHouseFingerprint(houseInterior)
    if not houseInterior or not houseInterior.furniture then return nil end
    local structuralTokens = {}
    local totalItems = 0
    
    for _, f in pairs(houseInterior.furniture) do
        totalItems = totalItems + 1
        table.insert(structuralTokens, tostring(f.id))
    end
    table.sort(structuralTokens)
    local structuralString = table.concat(structuralTokens, ",")
    
    local checksum = 0
    for i = 1, #structuralString do
        checksum = (checksum + string.byte(structuralString, i)) % 999999
    end
    
    return (houseInterior.building_type or "unknown") .. "_items" .. tostring(totalItems) .. "_sum" .. tostring(checksum)
end

local function parseHouseData(houseInterior)
    local data = { furnitures = {}, textures = {}, ambiances = {}, buildingType = houseInterior.building_type }
    if houseInterior.furniture then
        for _, furniture in pairs(houseInterior.furniture) do
            local colors = {}
            if furniture.colors then
                for i, color in pairs(furniture.colors) do 
                    colors[i] = typeof(color) == "Color3" and {color.R, color.G, color.B} or color 
                end
            end
            table.insert(data.furnitures, {
                kind = furniture.id,
                properties = { cframe = furniture.cframe and {furniture.cframe:GetComponents()} or nil, scale = furniture.scale, colors = next(colors) and colors or nil }
            })
        end
    end
    if houseInterior.textures then
        for roomName, texture in pairs(houseInterior.textures) do
            if texture and texture.walls then table.insert(data.textures, {room = roomName, type = "walls", id = texture.walls}) end
            if texture and texture.floors then table.insert(data.textures, {room = roomName, type = "floors", id = texture.floors}) end
        end
    end
    if houseInterior.ambiance then data.ambiances = houseInterior.ambiance end
    return data
end

