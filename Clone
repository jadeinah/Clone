-- ==================== DETERMINISTIC CLONE DETECTION ====================
local function getHouseFingerprint(houseInterior)
    if not houseInterior or type(houseInterior) ~= "table" or not houseInterior.furniture then return nil end
    local structuralTokens = {}
    local totalItems = 0
    for _, f in pairs(houseInterior.furniture) do
        totalItems = totalItems + 1
        table.insert(structuralTokens, tostring(f.id))
    end
    table.sort(structuralTokens)
    local structuralString = table.concat(structuralTokens, ",")
    local checksum = 0
    for i = 1, #structuralString do
        checksum = (checksum + string.byte(structuralString, i)) % 999999
    end
    return (houseInterior.building_type or "unknown") .. "_items" .. tostring(totalItems) .. "_sum" .. tostring(checksum)
end

local function parseHouseData(houseInterior)
    local data = { furnitures = {}, textures = {}, ambiances = {}, buildingType = houseInterior.building_type }
    if houseInterior.furniture then
        for _, f in pairs(houseInterior.furniture) do
            local colors = {}
            if f.colors then
                for i, c in pairs(f.colors) do colors[i] = typeof(c) == "Color3" and {c.R, c.G, c.B} or c end
            end
            table.insert(data.furnitures, {
                kind = f.id,
                properties = { cframe = f.cframe and {f.cframe:GetComponents()} or nil, scale = f.scale, colors = next(colors) and colors or nil }
            })
        end
    end
    if houseInterior.textures then
        for room, tex in pairs(houseInterior.textures) do
            if tex.walls then table.insert(data.textures, {room = room, type = "walls", id = tex.walls}) end
            if tex.floors then table.insert(data.textures, {room = room, type = "floors", id = tex.floors}) end
        end
    end
    if houseInterior.ambiance then data.ambiances = houseInterior.ambiance end
    return data
end

