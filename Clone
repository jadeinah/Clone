            warn("HTTP Request failed entirely. The executor may be blocking the domain.")
            SaveStatus:SetDesc("❌ Request blocked or failed locally.")
            Fluent:Notify({ Title = "Error", Content = "Failed to reach cloud server.", Duration = 3 })
