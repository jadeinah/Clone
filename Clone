Tabs.Scanner:AddButton({
    Title = "🔍 Scan Everything (Full House)",
    Callback = function()
        ScanStatus:SetDesc("Status: Scanning...")
        local player = Players.LocalPlayer
        local houseInterior = nil
        
        pcall(function()
            if ClientData.get_server then
                houseInterior = ClientData.get_server(player, "house_interior")
            elseif ClientData.get_data then
                houseInterior = ClientData.get_data()[player.Name].house_interior
            end
        end)
        
        if not houseInterior or not houseInterior.player then 
            ScanStatus:SetDesc("Status: ❌ No house interior found") 
            return 
        end

        scannedData = { furnitures = {}, textures = {}, ambiances = {}, buildingType = houseInterior.building_type }
        if not scannedData.buildingType then ScanStatus:SetDesc("Status: ❌ No building type") return end

        if houseInterior.furniture then
            for _, furniture in pairs(houseInterior.furniture) do
                local colors = {}
                if furniture.colors then
                    for i, color in pairs(furniture.colors) do 
                        colors[i] = typeof(color) == "Color3" and {color.R, color.G, color.B} or color 
                    end
                end
                table.insert(scannedData.furnitures, {
                    kind = furniture.id,
                    properties = { cframe = furniture.cframe and {furniture.cframe:GetComponents()} or nil, scale = furniture.scale, colors = next(colors) and colors or nil }
                })
            end
        end

        if houseInterior.textures then
            for roomName, texture in pairs(houseInterior.textures) do
                if texture and texture.walls then table.insert(scannedData.textures, {room = roomName, type = "walls", id = texture.walls}) end
                if texture and texture.floors then table.insert(scannedData.textures, {room = roomName, type = "floors", id = texture.floors}) end
            end
        end
        if houseInterior.ambiance then scannedData.ambiances = houseInterior.ambiance end

        writefile(CURRENT_SCAN_FILE, HttpService:JSONEncode(scannedData))
        local items, cost = calculateCost(scannedData)
        
        local costString = "$" .. tostring(cost)
        ScanStatus:SetDesc(string.format("✅ Saved! %d furnitures (Est. Value: %s)", items, costString))
        
        if PlaceStatus then 
            PlaceStatus:SetDesc(string.format("✅ Ready to place %d items.\n💰 Estimated Cost: %s", items, costString)) 
        end
        Fluent:Notify({ Title = "Scan Complete", Content = "House scanned successfully!", Duration = 3 })
    end
})

