-- ==================== AUTO TOUR (PHYSICAL DOOR HOPPER) ====================
task.spawn(function()
    while true do
        task.wait(3)
        if autoTourEnabled then
            pcall(function()
                local char = Players.LocalPlayer.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                
                local houseExteriors = workspace:FindFirstChild("HouseExteriors")
                if not houseExteriors then return end
                
                for _, plot in ipairs(houseExteriors:GetChildren()) do
                    local houseModel = plot:FindFirstChildWhichIsA("Model")
                    if houseModel then
                        -- Generate a unique key so we don't return to the same previous TP
                        local owner = plot:GetAttribute("Owner") or "Unknown"
                        local uniqueKey = plot.Name .. "_" .. houseModel.Name .. "_" .. tostring(owner)
                        
                        if not sessionVisitedPlots[uniqueKey] then
                            local door = houseModel:FindFirstChild("Doors") 
                                         and houseModel.Doors:FindFirstChild("MainDoor") 
                                         and houseModel.Doors.MainDoor:FindFirstChild("Door")
                                         
                            if door and door:IsA("BasePart") then
                                char.HumanoidRootPart.CFrame = door.CFrame + Vector3.new(0, 2, 0)
                                sessionVisitedPlots[uniqueKey] = true
                                
                                Fluent:Notify({
                                    Title = "Auto-Tour Active",
                                    Content = "Hopped to Plot " .. plot.Name .. " (" .. houseModel.Name .. ")",
                                    Duration = 3
                                })
                                
                                -- Wait 8 seconds at the door before jumping to the next to ensure interior loads
                                task.wait(8)
                                break 
                            end
                        end
                    end
                end
            end)
        end
    end
end)

